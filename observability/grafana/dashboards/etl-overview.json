{
  "uid": "nyc-taxi-etl",
  "title": "NYC Taxi ETL: Pipeline Health",
  "tags": ["etl", "nyc-taxi"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "dataset",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(etl_rows_loaded_total, dataset)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Rows loaded (last run): $dataset",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (dataset) (increase(etl_rows_loaded_total{dataset=~\"$dataset\"}[1h]))",
          "legendFormat": "{{dataset}}",
          "refId": "A"
        }
      ],
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Last successful load: $dataset",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "time() - max by (dataset) (etl_load_last_success_timestamp_seconds{dataset=~\"$dataset\"})",
          "legendFormat": "{{dataset}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3600},
              {"color": "red", "value": 86400}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Load failures (total)",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 5},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(etl_load_failures_total)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Load duration by dataset",
      "gridPos": {"x": 0, "y": 5, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "etl_load_duration_seconds{dataset=~\"$dataset\"}",
          "legendFormat": "{{dataset}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rows upserted per run",
      "gridPos": {"x": 12, "y": 5, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "increase(etl_rows_loaded_total{dataset=~\"$dataset\"}[5m])",
          "legendFormat": "{{dataset}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Warehouse live rows: nyc_taxi_trip_duration_*",
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pg_stat_user_tables_n_live_tup{relname=~\"nyc_taxi_trip_duration_.*\"}",
          "legendFormat": "{{relname}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Postgres connections",
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{datname}} / {{state}}",
          "refId": "A"
        }
      ]
    }
  ]
}
