# Copy to .env and fill in locally. Do not commit .env.
# The compose file reads these at `docker compose up` time.

# --- Postgres (used by Airflow's metadata DB AND by the ETL target DB) ---
POSTGRES_USER=airflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=airflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Airflow ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=

# --- MinIO (S3-compatible object store) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=nyc-taxi

# --- Local ETL orchestrator (run_all_etl.py) ---
# Superuser used to create the airflow role/DB on first run.
SUPERUSER_USER=
SUPERUSER_PASSWORD=

# --- ETL target DB (consumed by etl/load.py) ---
DB_USER=airflow
DB_PASSWORD=change-me
DB_NAME=airflow
DB_HOST=localhost
DB_PORT=5432
